# Copy to .env and fill in values

# Model selection (yolov8n | yolov8s | yolov8m | yolov8l | yolov8x)
YOLO_MODEL=yolov8n

# Detection confidence threshold (0.0 - 1.0)
CONFIDENCE=0.4

# IoU threshold for NMS
IOU_THRESHOLD=0.45

# Video source (0 for webcam, path/URL for file or RTSP)
VIDEO_SOURCE=0

# API server settings
API_HOST=0.0.0.0
API_PORT=8000

# Alert webhook (optional — POST when object threshold exceeded)
ALERT_WEBHOOK_URL=

# Speed calibration: pixels per meter at reference distance
PIXELS_PER_METER=50
